# ─────────────────────────────────────────────
# Oni — Environment Variables
# Copy to .env and fill in values before running docker compose
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Infrastructure
POSTGRES_PASSWORD=onidev
REDIS_URL=redis://redis:6379
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Application
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development

# Database (for direct connection from host tools / Alembic)
DATABASE_URL=postgresql+asyncpg://oni:onidev@localhost:5432/oni

# CORS — comma-separated list of allowed origins
# React Vite dev: http://localhost:5173
# React CRA dev:  http://localhost:3000
# Expo web:       exp://localhost:8081
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,exp://localhost:8081

# ─────────────────────────────────────────────
# Frontend (used by Vite / React Native)
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8001
